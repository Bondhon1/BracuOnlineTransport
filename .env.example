FLASK_DEBUG=false
SECRET_KEY=change-me-to-a-random-secret

# ---------------------------------------------------------------------------
# Database (MySQL). Free options: Railway, Aiven, Clever Cloud, FreeSQLDatabase.
# ---------------------------------------------------------------------------
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# ---------------------------------------------------------------------------
# Email — RECOMMENDED for free hosting: Brevo HTTP API (works over HTTPS).
# Many free hosts (e.g. Render free tier) block outbound SMTP ports, which is
# why registration/OTP fails. Set BREVO_API_KEY to send mail over HTTPS instead.
#   1. Create a free Brevo account (300 emails/day): https://www.brevo.com
#   2. Verify a sender email (the address mail is sent "from").
#   3. Settings -> SMTP & API -> API Keys -> create a key and paste it below.
# ---------------------------------------------------------------------------
BREVO_API_KEY=
MAIL_SENDER=your-verified-sender@example.com
MAIL_SENDER_NAME=University Transport System

# ---------------------------------------------------------------------------
# SMTP fallback (used only when BREVO_API_KEY is empty). For Gmail you MUST use
# an "App Password" (https://myaccount.google.com/apppasswords), not your normal
# password, and SMTP must not be blocked by your host.
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=15
